# Copy to .env.local for local development.
# Set these in the Render dashboard for the deployed service.

# Shared password for /login. Pick something strong; share via 1Password etc.
APP_PASSWORD=change-me-before-deploying

# HMAC secret for session cookies. Generate with: openssl rand -hex 32
# Render's render.yaml asks Render to generate one automatically on first deploy.
AUTH_SECRET=replace-with-32-plus-random-bytes
